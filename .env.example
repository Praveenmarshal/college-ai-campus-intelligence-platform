# ============================================================
# AI CAMPUS INTELLIGENCE PLATFORM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ----- App -----
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-in-production
APP_NAME=AI Campus Intelligence Platform

# Optional — lets you call POST /api/auth/seed once on a production deployment
# (e.g. a free-tier demo) by sending header "X-Seed-Secret: <this value>".
# Leave unset in normal production use.
SEED_SECRET=

# ----- MongoDB Atlas -----
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/campus_ai?retryWrites=true&w=majority
MONGO_DB_NAME=campus_ai

# ----- MongoDB local Docker container (only used if NOT using Atlas) -----
# These set up the bundled `mongo` service in docker-compose.yml.
# Generate real values with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=replace-with-a-generated-secret
MONGO_APP_USERNAME=campusadmin
MONGO_APP_PASSWORD=replace-with-a-generated-secret

# ----- JWT -----
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ----- LLM Provider -----
# "ollama" = local/self-hosted (Docker, bare metal, full data privacy — default)
# "groq"   = free hosted API (use this for free-tier demo deploys like Render,
#            which has no GPU/RAM to run Ollama). Get a free key, no card needed:
#            https://console.groq.com/keys
LLM_PROVIDER=gemini

# ----- Ollama (used when LLM_PROVIDER=ollama) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120

# ----- Groq (used when LLM_PROVIDER=groq) -----
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=60

# ----- Gemini (used when LLM_PROVIDER=gemini) -----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ----- ChromaDB -----
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=campus_docs

# ----- Embedding Model -----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- File Uploads -----
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=52428800
ALLOWED_EXTENSIONS=pdf,xlsx,xls,csv,png,jpg,jpeg,tiff

# ----- Google OAuth -----
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ----- CORS -----
FRONTEND_URL=http://localhost:5173

# ----- Email (SMTP) -----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@campus.edu

# ----- Twilio SMS -----
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ----- Rate Limiting -----
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ----- Frontend (Vite) -----
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_NAME=AI Campus Intelligence Platform
VITE_APP_VERSION=1.0.0
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
